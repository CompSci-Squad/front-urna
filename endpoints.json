{
  "baseUrl": "http://localhost:3000",
  "note": "All /elections/* routes are also available at /events/* for backwards compatibility.",
  "auth": {
    "adminKey": {
      "header": "x-admin-key",
      "description": "Required on all [admin] endpoints. Value must match the ADMIN_KEY environment variable."
    }
  },
  "endpoints": [
    {
      "id": "health",
      "method": "GET",
      "path": "/health",
      "auth": null,
      "params": {},
      "body": null,
      "response": {
        "200": { "ok": true, "ts": "<epoch ms>" }
      },
      "description": "Liveness probe."
    },

    {
      "id": "list-elections",
      "method": "GET",
      "path": "/elections",
      "auth": null,
      "params": {},
      "body": null,
      "response": {
        "200": [{ "address": "<0x…>", "name": "<string>", "description": "<string>" }]
      },
      "description": "Lists all elections deployed via the factory."
    },
    {
      "id": "create-election",
      "method": "POST",
      "path": "/elections",
      "auth": "adminKey",
      "params": {},
      "body": {
        "name": "<string, required>",
        "description": "<string, required>"
      },
      "response": {
        "201": { "address": "<0x…>", "txHash": "<0x…>" }
      },
      "description": "Deploys a new VotingContract via the factory."
    },
    {
      "id": "get-election",
      "method": "GET",
      "path": "/elections/:addr",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": {
        "200": {
          "address": "<0x…>",
          "name": "<string>",
          "description": "<string>",
          "state": "PENDING | OPEN | FINISHED",
          "electionId": "<string>",
          "voterMerkleRoot": "<string>",
          "races": [{ "raceId": 0, "name": "<string>", "candidates": [], "maxPicks": 1 }]
        }
      },
      "description": "Returns full election details including state and races."
    },
    {
      "id": "patch-election",
      "method": "PATCH",
      "path": "/elections/:addr",
      "auth": "adminKey",
      "params": { "addr": "contract address (0x…)" },
      "body": {
        "state": "OPEN | FINISHED"
      },
      "response": {
        "200": { "txHash": "<0x…>", "state": "OPEN | FINISHED" }
      },
      "description": "Drives the state machine: PENDING→OPEN (opens voting) or OPEN→FINISHED (locks results)."
    },

    {
      "id": "list-races",
      "method": "GET",
      "path": "/elections/:addr/races",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": {
        "200": [{ "raceId": 0, "name": "<string>", "maxPicks": 1, "candidates": [] }]
      },
      "description": "Returns all races for the election."
    },
    {
      "id": "create-race",
      "method": "POST",
      "path": "/elections/:addr/races",
      "auth": "adminKey",
      "params": { "addr": "contract address (0x…)" },
      "body": { "name": "<string, required>" },
      "response": {
        "201": { "raceId": "<number>", "txHash": "<0x…>" }
      },
      "description": "Creates a new race (raceId ≥ 1). Race 0 always exists by default."
    },
    {
      "id": "get-race",
      "method": "GET",
      "path": "/elections/:addr/races/:raceId",
      "auth": null,
      "params": { "addr": "contract address (0x…)", "raceId": "<integer ≥ 0>" },
      "body": null,
      "response": {
        "200": { "raceId": 0, "name": "<string>", "maxPicks": 1, "candidates": [] }
      },
      "description": "Returns a single race's details."
    },
    {
      "id": "patch-race",
      "method": "PATCH",
      "path": "/elections/:addr/races/:raceId",
      "auth": "adminKey",
      "params": { "addr": "contract address (0x…)", "raceId": "<integer ≥ 0>" },
      "body": {
        "name": "<string, optional — race 0 only>",
        "maxPicks": "<integer ≥ 1, optional>"
      },
      "response": {
        "200": { "txHash": "<0x…>" }
      },
      "description": "Updates race 0's display name or sets maxPicks (multi-choice voting). At least one field required."
    },

    {
      "id": "list-candidates",
      "method": "GET",
      "path": "/elections/:addr/races/:raceId/candidates",
      "auth": null,
      "params": { "addr": "contract address (0x…)", "raceId": "<integer ≥ 0>" },
      "body": null,
      "response": {
        "200": [{ "id": "<number>", "name": "<string>", "party": "<string>", "number": "<number>", "voteCount": "<string>" }]
      },
      "description": "Returns the candidate list for a race."
    },
    {
      "id": "create-candidate",
      "method": "POST",
      "path": "/elections/:addr/races/:raceId/candidates",
      "auth": "adminKey",
      "params": { "addr": "contract address (0x…)", "raceId": "<integer ≥ 0>" },
      "body": {
        "name": "<string, required>",
        "party": "<string, required>",
        "number": "<integer 1–998, required — 0=blank and 999=spoiled are reserved>"
      },
      "response": {
        "201": { "candidateId": "<number>", "txHash": "<0x…>" }
      },
      "description": "Adds a candidate to a race. Only allowed while election is PENDING."
    },
    {
      "id": "get-candidate",
      "method": "GET",
      "path": "/elections/:addr/races/:raceId/candidates/:candidateId",
      "auth": null,
      "params": {
        "addr": "contract address (0x…)",
        "raceId": "<integer ≥ 0>",
        "candidateId": "<integer>"
      },
      "body": null,
      "response": {
        "200": { "id": "<number>", "name": "<string>", "party": "<string>", "number": "<number>", "voteCount": "<string>" }
      },
      "description": "Returns a single candidate."
    },

    {
      "id": "list-voters",
      "method": "GET",
      "path": "/elections/:addr/voters",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": {
        "200": { "voterHashes": ["<decimal string>"], "merkleRoot": "<decimal string>" }
      },
      "description": "Lists all enrolled voter commitments (Poseidon hashes)."
    },
    {
      "id": "register-voters",
      "method": "POST",
      "path": "/elections/:addr/voters",
      "auth": "adminKey",
      "params": { "addr": "contract address (0x…)" },
      "body": {
        "hashes": ["<decimal string — Poseidon(voter_id), 1–16 entries>"],
        "merkleRoot": "<decimal string — Poseidon Merkle root of the voter set>"
      },
      "response": {
        "201": { "hashes": { "txHash": "<0x…>" }, "merkleRoot": { "txHash": "<0x…>" } }
      },
      "description": "Registers voter commitments on-chain then sets the Merkle root. Both operations are sequential (contract enforces that order)."
    },
    {
      "id": "get-voter-proof",
      "method": "GET",
      "path": "/elections/:addr/voters/:commitment",
      "auth": null,
      "params": {
        "addr": "contract address (0x…)",
        "commitment": "<decimal string — Poseidon(voter_id)>"
      },
      "body": null,
      "response": {
        "200": {
          "included": true,
          "leafIndex": "<number>",
          "pathElements": ["<string[4]>"],
          "pathIndices": ["<0 or 1, length 4>"],
          "root": "<string>"
        }
      },
      "description": "Returns the Merkle inclusion proof for a voter commitment. The voter's browser uses this to build the ZK circuit inputs without sending sensitive data to the backend."
    },

    {
      "id": "cast-vote",
      "method": "POST",
      "path": "/elections/:addr/votes",
      "auth": null,
      "headers": {
        "x-voter-token": "<optional — stable token for rate-limiting>",
        "x-forwarded-for": "<optional — client IP>"
      },
      "params": { "addr": "contract address (0x…)" },
      "body": {
        "raceId": "<integer ≥ 0>",
        "pubSignals": [
          "pubSignals[0]: merkle_root",
          "pubSignals[1]: nullifier_hash = Poseidon(voter_id, election_id, race_id)",
          "pubSignals[2]: candidate_id  (0=blank, 999=spoiled, else valid candidate)",
          "pubSignals[3]: election_id",
          "pubSignals[4]: race_id",
          "pubSignals[5]: pick_index"
        ],
        "proof": ["<24 decimal strings — PLONK proof field elements>"]
      },
      "response": {
        "202": { "txHash": "<0x…>", "nullifier": "<decimal string>" },
        "400": { "error": "<message>", "code": "INVALID_BODY | ELECTION_NOT_OPEN | SIGNAL_MISMATCH | RACE_NOT_FOUND | NULLIFIER_USED | NULLIFIER_PENDING" },
        "409": { "error": "<message>", "code": "NULLIFIER_USED" },
        "429": { "error": "Rate limit exceeded" }
      },
      "description": "Submits a ZK proof and calls castVote on-chain. Runs 11 security guards (state, signal consistency, nullifier checks, rate limit) before forwarding. Proof validity is enforced by the on-chain PlonkVerifier."
    },
    {
      "id": "get-vote-receipt",
      "method": "GET",
      "path": "/elections/:addr/votes/:nullifier",
      "auth": null,
      "params": {
        "addr": "contract address (0x…)",
        "nullifier": "<decimal string — pubSignals[1]>"
      },
      "body": null,
      "response": {
        "200": {
          "nullifier": "<string>",
          "status": "pending | submitted | confirmed",
          "txHash": "<0x…, if available>",
          "raceId": "<string, if available>",
          "candidateId": "<string, if confirmed>",
          "blockNumber": "<number, if confirmed>",
          "ts": "<epoch ms, if in pending log>"
        },
        "404": { "error": "No vote found for nullifier …" }
      },
      "description": "Looks up vote status. Checks the in-memory pending log first, then falls back to scanning on-chain VoteCast events."
    },
    {
      "id": "get-vote-receipt-pdf",
      "method": "GET",
      "path": "/elections/:addr/votes/:nullifier/receipt.pdf",
      "auth": null,
      "params": {
        "addr": "contract address (0x…)",
        "nullifier": "<decimal string — pubSignals[1]>"
      },
      "body": null,
      "response": {
        "200": "<application/pdf binary — voter receipt confirming on-chain recording, candidate voted, and race results>"
      },
      "description": "Generates a PDF receipt for the voter. The nullifier is their anonymous identifier — does not reveal identity."
    },
    {
      "id": "verify-proof",
      "method": "POST",
      "path": "/elections/:addr/verify-proof",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": {
        "raceId": "<integer ≥ 0>",
        "pubSignals": ["<6 decimal strings — same layout as /votes>"],
        "proof": ["<24 decimal strings — same layout as /votes>"]
      },
      "response": {
        "200": { "valid": true, "message": "Proof is acceptable for submission" },
        "400": { "error": "<message>", "code": "<guard that failed>" },
        "409": { "error": "<message>", "code": "NULLIFIER_USED" }
      },
      "description": "Dry-run: runs all vote guards (state, signals, nullifier) WITHOUT submitting the tx and WITHOUT consuming a rate-limit token. Used by the frontend for preflight validation."
    },

    {
      "id": "get-results",
      "method": "GET",
      "path": "/elections/:addr/results",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": {
        "200": {
          "electionName": "<string>",
          "electionId": "<string>",
          "state": "PENDING | OPEN | FINISHED",
          "snapshots": [{
            "raceId": "<string>",
            "name": "<string>",
            "candidates": [{ "id": "<string>", "name": "<string>", "party": "<string>", "number": "<string>", "voteCount": "<string>" }],
            "blankVotes": "<string>",
            "nullVotes": "<string>",
            "totalVotes": "<string>"
          }],
          "blockTimestamp": "<string>",
          "blockNumber": "<string>"
        }
      },
      "description": "Returns the full Boletim de Urna — all races with all candidate tallies."
    },
    {
      "id": "get-race-results",
      "method": "GET",
      "path": "/elections/:addr/races/:raceId/results",
      "auth": null,
      "params": { "addr": "contract address (0x…)", "raceId": "<integer ≥ 0>" },
      "body": null,
      "response": {
        "200": {
          "electionName": "<string>",
          "electionId": "<string>",
          "state": "<string>",
          "raceId": "<string>",
          "raceName": "<string>",
          "candidates": [],
          "blankVotes": "<string>",
          "nullVotes": "<string>",
          "totalVotes": "<string>",
          "blockTimestamp": "<string>",
          "blockNumber": "<string>"
        }
      },
      "description": "Same as /results but for a single race."
    },
    {
      "id": "get-bu-pdf",
      "method": "GET",
      "path": "/elections/:addr/audit/bu.pdf",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": {
        "200": "<application/pdf binary — official Boletim de Urna tally document>"
      },
      "description": "Tally results as a downloadable PDF. Available in any state; most meaningful after FINISHED."
    },
    {
      "id": "get-bu-json",
      "method": "GET",
      "path": "/elections/:addr/audit/bu",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": { "200": "<same shape as /results>" },
      "description": "Alias for /results."
    },
    {
      "id": "get-zeresima",
      "method": "GET",
      "path": "/elections/:addr/audit/zeresima",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": {
        "200": {
          "electionName": "<string>",
          "electionId": "<string>",
          "state": "PENDING",
          "certifiedAt": "<ISO timestamp>",
          "races": [{ "raceId": "<string>", "name": "<string>", "totalVotes": "0" }]
        }
      },
      "description": "Zero-vote certificate. Attests that no votes exist before the election opens (PENDING state only)."
    },
    {
      "id": "get-rdv",
      "method": "GET",
      "path": "/elections/:addr/audit/rdv",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": {
        "200": {
          "electionName": "<string>",
          "logs": [{
            "nullifier": "<string>",
            "raceId": "<string>",
            "candidateId": "<string>",
            "txHash": "<0x…>",
            "blockNumber": "<number>"
          }]
        }
      },
      "description": "Registro Digital de Voto — full log of VoteCast on-chain events. Allows independent vote-by-vote audit."
    },
    {
      "id": "get-pending-log",
      "method": "GET",
      "path": "/elections/:addr/audit/pending",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": {
        "200": {
          "currentEpoch": [{ "nullifier": "<string>", "submitted": "<bool>", "txHash": "<0x…?>", "raceId": "<string>", "ts": "<epoch ms>" }],
          "history": [{ "epoch": "<string>", "entries": [] }]
        }
      },
      "description": "In-flight accountability log (in-memory). Shows proofs received but not yet confirmed, plus archived epochs."
    },

    {
      "id": "legacy-relay",
      "method": "POST",
      "path": "/events/:addr/relay",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": {
        "raceId": "<integer ≥ 0>",
        "pubSignals": ["<6 decimal strings>"],
        "proof": ["<24 decimal strings>"]
      },
      "response": {
        "200": { "txHash": "<0x…>" },
        "400": { "error": "<message>", "code": "<string>" },
        "409": { "error": "<message>", "code": "NULLIFIER_PENDING | NULLIFIER_USED" },
        "429": { "error": "Rate limit exceeded" }
      },
      "description": "Legacy vote submission endpoint (pre-/elections era). Same guards as POST /elections/:addr/votes. Kept for backwards compatibility."
    },
    {
      "id": "admin-state",
      "method": "GET",
      "path": "/events/:addr/admin/state",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": {
        "200": { "state": "<string>", "races": [] }
      },
      "description": "Full event state + races. Read-only helper for the admin UI."
    },
    {
      "id": "admin-voters",
      "method": "GET",
      "path": "/events/:addr/admin/voters",
      "auth": null,
      "params": { "addr": "contract address (0x…)" },
      "body": null,
      "response": {
        "200": { "voterHashes": ["<decimal string>"], "count": "<number>" }
      },
      "description": "Returns all voter hashes registered on-chain. Publicly auditable."
    }
  ]
}
